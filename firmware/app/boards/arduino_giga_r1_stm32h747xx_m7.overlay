/*
 * ZPLC Board Overlay - Arduino GIGA R1 (Cortex-M7)
 * SPDX-License-Identifier: MIT
 *
 * The Arduino GIGA R1 already defines:
 *   - led0 = red_led (PI12)
 *   - led1 = green_led (PJ13)
 *   - sw0 = user_button (PC13)
 *
 * This overlay intentionally does not redefine flash partitions.
 * Arduino GIGA board DTS already provides `storage_partition` on QSPI.
 */

/ {
    /* Board has sufficient default aliases for ZPLC GPIO HAL */
};
