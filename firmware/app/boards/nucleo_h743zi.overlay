/*
 * ZPLC Board Overlay - ST Nucleo H743ZI
 * SPDX-License-Identifier: MIT
 *
 * The Nucleo H743ZI already defines:
 *   - led0 = green_led (PB0)
 *   - led1 = yellow_led (PE1)
 *   - sw0 = user_button (PC13)
 *
 * This overlay adds:
 *   - Storage partition for NVS (program persistence)
 *
 * Flash Layout (2MB total):
 *   The H743ZI has 2MB flash with 128KB sectors.
 *   We reserve the last 128KB for NVS storage.
 */

/ {
    /* Board has sufficient default aliases for ZPLC GPIO HAL */
};

/*
 * The upstream Nucleo H743ZI board DTS already defines `storage_partition`
 * on internal flash. Do not redefine it here or devicetree label collisions
 * will break the build.
 */
