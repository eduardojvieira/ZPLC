/*
 * ZPLC Board Overlay - STM32F746G Discovery
 * SPDX-License-Identifier: MIT
 *
 * The STM32F746G-DISCO board DTS defines:
 *   - flash0: internal STM32 flash (1MB, non-uniform sector layout)
 *   - n25q128a1: external QSPI NOR flash (16MB)
 *     - storage_partition @ 0xa0000 on QSPI (15MB usable)
 *
 * Settings storage backend:
 *   CONFIG_SETTINGS_NVS is NOT used here because NVS requires flash sector
 *   size <= UINT16_MAX (64KB). The STM32F746 internal flash has sectors of
 *   32KB (small) and 256KB (large). Placing NVS on a 256KB sector returns
 *   -EDOM (-33) in settings_backend_init() (nvs_sector_size > UINT16_MAX).
 *
 *   Instead we use CONFIG_SETTINGS_FILE backed by LittleFS mounted on the
 *   external QSPI NOR flash (storage_partition). The QSPI NOR driver supports
 *   all LittleFS flash operations (read/prog/erase/sync).
 *
 *   No DTS changes needed: storage_partition is already defined in the board
 *   DTS and FIXED_PARTITION_ID(storage_partition) resolves to the QSPI NOR.
 *   LittleFS is mounted by zplc_config_init() before settings_subsys_init().
 *
 * Modbus RTU wiring (production-style):
 *   - USART6 TX = PC6 = Arduino D1
 *   - USART6 RX = PC7 = Arduino D0
 *   - DE/RE control = PA15 = Arduino D9
 */


&usart6 {
	modbus0: modbus0 {
		compatible = "zephyr,modbus-serial";
		de-gpios = <&gpioa 15 GPIO_ACTIVE_HIGH>;
		status = "okay";
	};
};
